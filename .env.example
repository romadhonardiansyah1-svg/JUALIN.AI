# ═══════════════════════════════════════════
# JUALIN.AI — Environment Variables
# Copy ke .env dan sesuaikan
# ═══════════════════════════════════════════

# Database
DB_PASSWORD=jualin_secure_2026

# Security (WAJIB ganti di production!)
SECRET_KEY=ganti-dengan-random-string-panjang-32-karakter
JWT_SECRET_KEY=ganti-dengan-jwt-secret-panjang-32-karakter

# LLM (via 9Router)
LLM_BASE_URL=http://host.docker.internal:20128/v1
LLM_API_KEY=not-needed
LLM_MODEL=llama-3.1-8b-instant

# Gemini (opsional)
GEMINI_API_KEY=

# Domain (ganti dengan domain asli)
DOMAIN=localhost
BASE_URL=http://localhost
FRONTEND_URL=http://localhost

# Mode
DEBUG=false
WEB_CONCURRENCY=1
SCHEDULER_ENABLED=true

# Feature flags scale-up
ENABLE_WHATSAPP=false
ENABLE_AI_ACTIONS=false
ENABLE_CAMPAIGNS=false
ENABLE_WORKFLOWS=false
ENABLE_BILLING=false
ENABLE_MARKETPLACE_IMPORT=false
ENABLE_AI_QUALITY=true

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v20.0
WHATSAPP_APP_SECRET=
