# JUALIN.AI Environment Variables
# Copy this file to .env and fill in your values

# App
DEBUG=true
SECRET_KEY=change-this-to-a-random-string

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jualin_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-this-to-a-random-jwt-secret
JWT_EXPIRE_MINUTES=1440

# LLM — via 9Router (recommended)
LLM_BASE_URL=http://localhost:20128/v1
LLM_API_KEY=not-needed
LLM_MODEL=llama-3.1-8b-instant

# OR direct to Groq (without 9Router)
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_your_groq_key_here
# LLM_MODEL=llama-3.1-8b-instant

# Gemini (for image AI + backup)
GEMINI_API_KEY=your_gemini_api_key_here

# CORS
CORS_ORIGINS=["http://localhost:3000"]
