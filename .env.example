# ═══════════════════════════════════════════
# JUALIN.AI — Environment Variables
# Copy ke .env dan sesuaikan
# ═══════════════════════════════════════════

# Database
DB_PASSWORD=jualin_secure_2026

# Security (WAJIB ganti di production!)
# Generate:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=ganti-dengan-random-string-minimal-48-karakter
JWT_SECRET_KEY=ganti-dengan-jwt-secret-minimal-48-karakter
MIN_PASSWORD_LENGTH=10
MAX_JSON_BODY_BYTES=2097152
MAX_MULTIPART_BODY_BYTES=8388608

# LLM (via 9Router)
LLM_BASE_URL=http://host.docker.internal:20128/v1
LLM_API_KEY=not-needed
LLM_MODEL=llama-3.1-8b-instant

# Gemini (opsional)
GEMINI_API_KEY=

# Domain
DOMAIN=jualan-ai.cloud
BASE_URL=https://jualan-ai.cloud
FRONTEND_URL=https://jualan-ai.cloud

# Mode
DEBUG=false
WEB_CONCURRENCY=1
SCHEDULER_ENABLED=false
AUTO_CREATE_TABLES=false
ARQ_MAX_JOBS=2

# Feature flags scale-up
ENABLE_WHATSAPP=false
ENABLE_AI_ACTIONS=false
ENABLE_CAMPAIGNS=false
ENABLE_WORKFLOWS=false
ENABLE_BILLING=false
ENABLE_MARKETPLACE_IMPORT=false
ENABLE_AI_QUALITY=true

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v20.0
WHATSAPP_APP_SECRET=
