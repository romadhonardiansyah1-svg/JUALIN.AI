# ═══════════════════════════════════════════
# JUALIN.AI — Production Environment Config
# Copy ke .env dan isi value yang diperlukan
# ═══════════════════════════════════════════

# App
DEBUG=false
# Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=GANTI_RANDOM_STRING_MINIMAL_48_KARAKTER

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://jualin:GANTI_PASSWORD@localhost:5432/jualin_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=GANTI_JWT_SECRET_MINIMAL_48_KARAKTER
JWT_EXPIRE_MINUTES=1440
MIN_PASSWORD_LENGTH=10
MAX_JSON_BODY_BYTES=2097152
MAX_MULTIPART_BODY_BYTES=8388608

# LLM (via 9Router)
LLM_BASE_URL=http://localhost:20128/v1
LLM_API_KEY=not-needed
LLM_MODEL=llama-3.1-8b-instant

# Gemini API (backup)
GEMINI_API_KEY=

# CORS
CORS_ORIGINS=["https://yourdomain.com","http://localhost:3000"]

# Embedding model (auto-download on first run)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── URLs ──
BASE_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ── Payment Gateways ──

# Midtrans (https://dashboard.midtrans.com/)
# Sandbox: https://dashboard.sandbox.midtrans.com/
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Cashi.id (https://cashi.id/merchant)
CASHI_API_KEY=
CASHI_BASE_URL=https://cashi.id/api

# Default payment provider: "cashi" or "midtrans"
DEFAULT_PAYMENT_PROVIDER=cashi
