# ═══════════════════════════════════════════
# JUALIN.AI — Production Environment Config
# Copy ke .env dan isi value yang diperlukan
# ═══════════════════════════════════════════

# App
DEBUG=false
SECRET_KEY=GANTI_RANDOM_STRING_32_KARAKTER

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://jualin:GANTI_PASSWORD@localhost:5432/jualin_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=GANTI_JWT_SECRET_32_KARAKTER
JWT_EXPIRE_MINUTES=1440

# LLM (via 9Router)
LLM_BASE_URL=http://localhost:20128/v1
LLM_API_KEY=not-needed
LLM_MODEL=llama-3.1-8b-instant

# Gemini API (backup)
GEMINI_API_KEY=

# CORS
CORS_ORIGINS=["https://yourdomain.com","http://localhost:3000"]

# Embedding model (auto-download on first run)
EMBEDDING_MODEL=all-MiniLM-L6-v2
